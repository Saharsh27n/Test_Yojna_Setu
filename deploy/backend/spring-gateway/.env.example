# ── Supabase PostgreSQL ─────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Database
# Use port 5432 (direct/session mode) — NOT 6543 (transaction pooler)
DB_URL=jdbc:postgresql://db.<YOUR-PROJECT-REF>.supabase.co:5432/postgres?sslmode=require
DB_USER=postgres
DB_PASS=<YOUR-SUPABASE-DB-PASSWORD>

# ── JWT Secret ───────────────────────────────────────────────────────────────────
# Generate a long random string: openssl rand -hex 32
JWT_SECRET=<CHANGE-ME-use-openssl-rand-hex-32>

# ── Services ─────────────────────────────────────────────────────────────────────
FASTAPI_URL=http://localhost:8001
FRONTEND_URL=http://localhost:5173
